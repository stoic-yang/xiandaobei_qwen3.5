d\u9632\u62a4\u63aa\u65bd\uff08\u5982\u4f69\u6234\u5bc6\u5c01\u6027\u597d\u7684\u6cf3\u955c\u3001\u4f7f\u7528\u65e5\u629b\u578b\u955c\u7247\uff09\u7684\u60c5\u51b5\u4e0b\u201c\u53ef\u4ee5\u201d\u6234\uff0c\u4f46**\u7edd\u5927\u591a\u6570\u4e13\u4e1a\u5efa\u8bae\u548c\u5e38\u8bc6\uff08\u6587\u7ae0 1\u30014\u30015\uff09\u90fd\u5f3a\u70c8\u53cd\u5bf9\u5728\u6e38\u6cf3\u65f6\u4f69\u6234\u9690\u5f62\u773c\u955c**\u3002\n\n\u4e3b\u8981\u539f\u56e0\u53ca\u98ce\u9669\u5982\u4e0b\uff1a\n\n1.  **\u5316\u5b66\u523a\u6fc0\u4e0e\u611f\u67d3\u98ce\u9669**\uff1a\n    *   **\u6cf3\u6c60\u6c34**\uff1a\u542b\u6709\u6c2f\u548c\u5176\u4ed6\u5316\u5b66\u7269\u8d28\u3002\u8f6f\u6027\u9690\u5f62\u773c\u955c\u5177\u6709\u5438\u6c34\u6027\uff0c\u4f1a\u5438\u6536\u8fd9\u4e9b\u5316\u5b66\u7269\u8d28\u5e76\u6d53\u7f29\u5728\u955c\u7247\u4e0a\uff0c\u76f4\u63a5\u523a\u6fc0\u773c\u89d2\u819c\u548c\u7ed3\u819c\uff0c\u5bfc\u81f4\u773c\u775b\u53d1\u7ea2\u3001\u75bc\u75db\u3001\u754f\u5149\u3002\n    *   **\u81ea\u7136\u6c34\u57df**\uff08\u6d77\u6c34\u3001\u6cb3\u6d41\u3001\u6e56\u6cca\uff09\uff1a\u542b\u6709\u5927\u91cf\u5fae\u751f\u7269\u3001\u7ec6\u83cc\uff08\u5982\u5927\u80a0\u6746\u83cc\uff09\u548c\u5bc4\u751f\u866b\uff08\u5982\u963f\u7c73\u5df4\u53d8\u5f62\u866b\uff09\u3002\u9690\u5f62\u773c\u955c\u5bb9\u6613\u5438\u9644\u8fd9\u4e9b\u6c61\u67d3\u7269\uff0c\u4e00\u65e6\u63a5\u89e6\u773c\u7403\uff0c\u6781\u6613\u5f15\u53d1\u4e25\u91cd\u7684\u773c\u90e8\u611f\u67d3\uff0c\u751a\u81f3\u5bfc\u81f4\u89d2\u819c\u6c38\u4e45\u53d7\u635f\u3002\n\n2.  **\u955c\u7247\u8131\u843d\u4e0e\u7269\u7406\u635f\u4f24**\uff1a\n    *   \u9690\u5f62\u773c\u955c\u9047\u6c34\u5bb9\u6613\u53d8\u5f62\u6216\u8131\u843d\u3002\u6e38\u6cf3\u65f6\u6c34\u6d41\u51b2\u51fb\u5927\uff0c\u955c\u7247\u6781\u6613\u79fb\u4f4d\u6216\u4e22\u5931\u3002\n    *   \u5982\u679c\u6c34\u8fdb\u5165\u6cf3\u955c\uff0c\u4f69\u6234\u8005\u4e0b\u610f\u8bc6\u5730\u63c9\u773c\u775b\uff0c\u6781\u6613\u5c06\u7ec6\u83cc\u5e26\u5165\u6216\u9020\u6210\u89d2\